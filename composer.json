{
    "name": "bpjs/auth-client",
    "description": "Shared auth client for all apps",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Bpjs\\AuthServiceClient\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Fadli Azka Prayogi",
            "email": "fadliazkaprayogi1@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.0",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "10.0"
    },
     "autoload-dev": {
        "psr-4": {
            "Bpjs\\AuthServiceClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
